# Szallas.hu Scraper Configuration Template
# Copy this file to '.env' and fill in your details.

# 1. ScraperAPI key (Get a free key with 5000 requests/month at scraperapi.com)
# Recommended for bypassing Cloudflare when running in the cloud (Streamlit Cloud).
SCRAPERAPI_KEY=your_scraperapi_key_here

# 2. General Proxy URL (Optional, format: http://username:password@ip:port or http://ip:port)
PROXY_URL=
